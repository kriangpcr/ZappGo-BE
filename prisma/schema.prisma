generator client {
  provider   = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL2")

}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  role       String   @default("USER")
  created_at DateTime @default(now())
}
